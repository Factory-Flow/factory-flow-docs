{
    "openapi": "3.1.0",
    "info": {
        "title": "Factory Flow",
        "version": "0.0.1",
        "description": "Factory Flow public API. Authenticate using your organization API token as a Bearer token."
    },
    "servers": [
        {
            "url": "https://app.factoryflow.test/api"
        }
    ],
    "security": [
        {
            "bearerAuth": []
        }
    ],
    "paths": {
        "/production": {
            "post": {
                "operationId": "production",
                "description": "Report part count data for one or more machines in a single request (max 25).\nEach reading requires `machine_uuid` plus `part_count_total`. If only one of\n`part_count_good` or `part_count_bad` is provided the other is derived automatically.\nAll machines must belong to the authenticated organization and use the `factory_flow_api` data source.",
                "summary": "Submit part count readings",
                "tags": [
                    "BatchMachineParts"
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "readings": {
                                        "type": "array",
                                        "items": {
                                            "type": "object",
                                            "properties": {
                                                "machine_uuid": {
                                                    "type": "string",
                                                    "format": "uuid"
                                                },
                                                "part_count_total": {
                                                    "type": "integer",
                                                    "minimum": 0
                                                },
                                                "part_count_good": {
                                                    "type": [
                                                        "integer",
                                                        "null"
                                                    ],
                                                    "minimum": 0
                                                },
                                                "part_count_bad": {
                                                    "type": [
                                                        "integer",
                                                        "null"
                                                    ],
                                                    "minimum": 0
                                                }
                                            },
                                            "required": [
                                                "machine_uuid",
                                                "part_count_total"
                                            ]
                                        },
                                        "minItems": 1,
                                        "maxItems": 25
                                    }
                                },
                                "required": [
                                    "readings"
                                ]
                            }
                        }
                    }
                },
                "responses": {
                    "202": {
                        "description": "Readings accepted.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "status": {
                                            "type": "string"
                                        },
                                        "count": {
                                            "type": "integer"
                                        }
                                    },
                                    "required": [
                                        "status",
                                        "count"
                                    ]
                                }
                            }
                        }
                    },
                    "429": {
                        "description": "Rate limit exceeded.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "message": {
                                            "type": "string"
                                        },
                                        "retry_after": {
                                            "type": "integer"
                                        },
                                        "throttled_machines": {
                                            "type": "array",
                                            "items": {
                                                "type": "string",
                                                "format": "uuid"
                                            }
                                        }
                                    },
                                    "required": [
                                        "message",
                                        "retry_after",
                                        "throttled_machines"
                                    ]
                                }
                            }
                        }
                    }
                }
            }
        },
        "/machines": {
            "get": {
                "operationId": "machines.index",
                "tags": [
                    "Machines"
                ],
                "responses": {
                    "200": {
                        "description": "",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "$ref": "#/components/schemas/MachineResource"
                                            }
                                        },
                                        "meta": {
                                            "type": "object",
                                            "properties": {
                                                "current_page": {
                                                    "type": "integer"
                                                },
                                                "per_page": {
                                                    "type": "integer"
                                                },
                                                "total": {
                                                    "type": "integer"
                                                },
                                                "last_page": {
                                                    "type": "integer"
                                                }
                                            },
                                            "required": [
                                                "current_page",
                                                "per_page",
                                                "total",
                                                "last_page"
                                            ]
                                        },
                                        "links": {
                                            "type": "object",
                                            "properties": {
                                                "first": {
                                                    "type": "string"
                                                },
                                                "last": {
                                                    "type": [
                                                        "string",
                                                        "null"
                                                    ]
                                                },
                                                "prev": {
                                                    "type": [
                                                        "string",
                                                        "null"
                                                    ]
                                                },
                                                "next": {
                                                    "type": [
                                                        "string",
                                                        "null"
                                                    ]
                                                }
                                            },
                                            "required": [
                                                "first",
                                                "last",
                                                "prev",
                                                "next"
                                            ]
                                        }
                                    },
                                    "required": [
                                        "data",
                                        "meta",
                                        "links"
                                    ]
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "components": {
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "scheme": "bearer"
            }
        },
        "schemas": {
            "CycleTimeThreshold": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "string"
                    },
                    "label": {
                        "type": "string"
                    },
                    "value": {
                        "type": "number"
                    },
                    "color": {
                        "type": [
                            "string",
                            "null"
                        ]
                    },
                    "downtime": {
                        "type": [
                            "boolean",
                            "null"
                        ]
                    }
                },
                "required": [
                    "id",
                    "label",
                    "value"
                ],
                "title": "CycleTimeThreshold"
            },
            "DetectionWindow": {
                "type": "object",
                "properties": {
                    "enabled": {
                        "type": "boolean"
                    },
                    "window_minutes": {
                        "type": [
                            "integer",
                            "null"
                        ]
                    }
                },
                "required": [
                    "enabled",
                    "window_minutes"
                ],
                "title": "DetectionWindow"
            },
            "FacilityRef": {
                "type": "object",
                "properties": {
                    "uuid": {
                        "type": "string",
                        "format": "uuid",
                        "example": "7c3a1b2d-4e5f-6a7b-8c9d-0e1f2a3b4c5d"
                    },
                    "name": {
                        "type": "string",
                        "example": "Main Factory Floor"
                    },
                    "location": {
                        "type": [
                            "string",
                            "null"
                        ]
                    }
                },
                "required": [
                    "uuid",
                    "name",
                    "location"
                ],
                "title": "FacilityRef"
            },
            "LineRef": {
                "type": "object",
                "properties": {
                    "uuid": {
                        "type": "string",
                        "format": "uuid"
                    },
                    "name": {
                        "type": "string"
                    },
                    "part_number": {
                        "type": [
                            "string",
                            "null"
                        ]
                    },
                    "description": {
                        "type": [
                            "string",
                            "null"
                        ]
                    }
                },
                "required": [
                    "uuid",
                    "name",
                    "part_number",
                    "description"
                ],
                "title": "LineRef"
            },
            "MachineDataSource": {
                "type": "string",
                "enum": [
                    "none",
                    "factory_flow_api",
                    "factory_flow_gateway"
                ],
                "title": "MachineDataSource"
            },
            "MachineResource": {
                "type": "object",
                "properties": {
                    "uuid": {
                        "type": "string",
                        "format": "uuid",
                        "example": "9d4e2f8a-1b3c-4d5e-6f7a-8b9c0d1e2f3a"
                    },
                    "name": {
                        "type": "string",
                        "example": "CNC Mill #1"
                    },
                    "facility": {
                        "anyOf": [
                            {
                                "$ref": "#/components/schemas/FacilityRef"
                            },
                            {
                                "type": "null"
                            }
                        ]
                    },
                    "machine_type": {
                        "anyOf": [
                            {
                                "$ref": "#/components/schemas/MachineTypeRef"
                            },
                            {
                                "type": "null"
                            }
                        ]
                    },
                    "data_source": {
                        "$ref": "#/components/schemas/MachineDataSource"
                    },
                    "shifts": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/ShiftRef"
                        }
                    },
                    "lines": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/LineRef"
                        }
                    },
                    "analytics": {
                        "type": "object",
                        "properties": {
                            "expected_cycle_time": {
                                "type": [
                                    "number",
                                    "null"
                                ]
                            },
                            "cycle_time_thresholds": {
                                "type": "array",
                                "items": {
                                    "$ref": "#/components/schemas/CycleTimeThreshold"
                                }
                            },
                            "oee_thresholds": {
                                "anyOf": [
                                    {
                                        "$ref": "#/components/schemas/OeeThresholds"
                                    },
                                    {
                                        "type": "null"
                                    }
                                ]
                            },
                            "shift_change_detection": {
                                "$ref": "#/components/schemas/DetectionWindow"
                            },
                            "break_creep_detection": {
                                "$ref": "#/components/schemas/DetectionWindow"
                            }
                        },
                        "required": [
                            "expected_cycle_time",
                            "cycle_time_thresholds",
                            "oee_thresholds",
                            "shift_change_detection",
                            "break_creep_detection"
                        ]
                    }
                },
                "required": [
                    "uuid",
                    "name",
                    "data_source",
                    "analytics"
                ],
                "title": "MachineResource"
            },
            "MachineTypeRef": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 3
                    },
                    "name": {
                        "type": "string",
                        "example": "CNC Mill"
                    }
                },
                "required": [
                    "id",
                    "name"
                ],
                "title": "MachineTypeRef"
            },
            "OeeThresholdConfig": {
                "type": "object",
                "properties": {
                    "green": {
                        "type": "number"
                    },
                    "yellow": {
                        "type": "number"
                    },
                    "orange": {
                        "type": "number"
                    }
                },
                "required": [
                    "green",
                    "yellow",
                    "orange"
                ],
                "title": "OeeThresholdConfig"
            },
            "OeeThresholds": {
                "type": "object",
                "properties": {
                    "overall": {
                        "anyOf": [
                            {
                                "$ref": "#/components/schemas/OeeThresholdConfig"
                            },
                            {
                                "type": "null"
                            }
                        ]
                    },
                    "availability": {
                        "anyOf": [
                            {
                                "$ref": "#/components/schemas/OeeThresholdConfig"
                            },
                            {
                                "type": "null"
                            }
                        ]
                    },
                    "performance": {
                        "anyOf": [
                            {
                                "$ref": "#/components/schemas/OeeThresholdConfig"
                            },
                            {
                                "type": "null"
                            }
                        ]
                    },
                    "quality": {
                        "anyOf": [
                            {
                                "$ref": "#/components/schemas/OeeThresholdConfig"
                            },
                            {
                                "type": "null"
                            }
                        ]
                    }
                },
                "title": "OeeThresholds"
            },
            "ShiftRef": {
                "type": "object",
                "properties": {
                    "uuid": {
                        "type": "string",
                        "format": "uuid"
                    },
                    "name": {
                        "type": "string"
                    }
                },
                "required": [
                    "uuid",
                    "name"
                ],
                "title": "ShiftRef"
            }
        },
        "responses": {
            "ValidationException": {
                "description": "Validation error",
                "content": {
                    "application/json": {
                        "schema": {
                            "type": "object",
                            "properties": {
                                "message": {
                                    "type": "string",
                                    "description": "Errors overview."
                                },
                                "errors": {
                                    "type": "object",
                                    "description": "A detailed description of each field that failed validation.",
                                    "additionalProperties": {
                                        "type": "array",
                                        "items": {
                                            "type": "string"
                                        }
                                    }
                                }
                            },
                            "required": [
                                "message",
                                "errors"
                            ]
                        }
                    }
                }
            }
        }
    }
}