{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Factory Flow",
  "colors": {
    "primary": "#0565ff",
    "light": "#0565ff",
    "dark": "#0565ff"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Status",
          "icon": "signal-stream",
          "href": "https://status.factoryflow.io"
        },
        {
          "anchor": "Support",
          "icon": "life-ring",
          "href": "mailto:support@factoryflow.io"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Guides",
        "pages": [
          {
            "group": "Getting Started",
            "pages": [
              "introduction",
              "quickstart",
              "concepts"
            ]
          },
          {
            "group": "Monitor",
            "pages": [
              "monitor/analytics",
              "monitor/layouts",
              "monitor/alerts"
            ]
          },
          {
            "group": "Configure",
            "pages": [
              "configure/machines",
              "configure/lines",
              "configure/facilities",
              "configure/shifts",
              "configure/alert-rules"
            ]
          },
          {
            "group": "Manage",
            "pages": [
              "manage/team",
              "manage/organization",
              "manage/profile"
            ]
          },
          {
            "group": "Self-Hosted",
            "pages": [
              "self-hosted/overview",
              "self-hosted/installation",
              "self-hosted/license",
              {
                "group": "Configure",
                "pages": [
                  "self-hosted/smtp",
                  "self-hosted/ldap"
                ]
              },
              {
                "group": "Manage",
                "pages": [
                  "self-hosted/updates",
                  "self-hosted/backups",
                  "self-hosted/data-retention"
                ]
              },
              {
                "group": "Administration",
                "pages": [
                  "self-hosted/admin-management",
                  "self-hosted/cli-reference"
                ]
              }
            ]
          }
        ]
      },
      {
        "tab": "Changelog",
        "pages": [
          "release-notes"
        ]
      },
      {
        "tab": "API",
        "openapi": "/api/openapi.json",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api/introduction"
            ]
          }
        ]
      }
    ]
  },
  "api": {
    "baseUrl": "https://app.factoryflow.io/api",
    "auth": {
      "method": "bearer",
      "name": "Authorization",
      "inputPrefix": "Bearer "
    },
    "playground": {
      "mode": "show"
    }
  },
  "openapi": "/api/openapi.json",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@factoryflow.io"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open Factory Flow",
      "href": "https://app.factoryflow.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  }
}
